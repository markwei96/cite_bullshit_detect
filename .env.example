# LLM API Configuration
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Google Scholar API Keys (at least one required)
# ScrapingDog: 1000 credits/month, 5 credits per search
# SerpAPI: 250 searches/month
SCRAPINGDOG_KEYS=key1,key2
SERPAPI_KEYS=key1,key2

# PDF Parser: firered (default), mineru, or pymupdf
PDF_PARSER=firered

# FireRed-OCR settings (only needed if PDF_PARSER=firered)
# Model path: HuggingFace model ID or local path
FIRERED_MODEL_DIR=FireRedTeam/FireRed-OCR
# Path to FireRed-OCR repo (for conv_for_infer.py)
FIRERED_OCR_DIR=~/code/FireRed-OCR
